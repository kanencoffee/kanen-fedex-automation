# FedEx REST API credentials (from FedEx Developer Portal)
FEDEX_CLIENT_ID=your_client_id_here
FEDEX_CLIENT_SECRET=your_client_secret_here
FEDEX_ACCOUNT_NUMBER=your_account_number_here

# Railway auto-provides DATABASE_URL — override for local dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/kanen_fedex

# The public URL Railway assigns your backend (needed for webhook subscriptions)
APP_BASE_URL=https://your-app.railway.app

# Webhook shared secret — set to something random, must match subscription
FEDEX_WEBHOOK_SECRET=change-me-to-something-random

# Billing discrepancy threshold in USD (default $5.00)
BILLING_ALERT_THRESHOLD=5.00

# Optional: email alerts for exceptions and billing flags
ALERT_EMAIL=sam@kanencoffee.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
